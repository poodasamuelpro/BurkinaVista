# ============================
# BurkinaVista — Variables d'environnement
# ============================
# IMPORTANT : Ne jamais commiter ce fichier avec de vraies valeurs !
# Copier vers .env.local et remplir les valeurs

# ── Neon PostgreSQL ──────────────────────────────────────────
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ── Cloudinary (stockage photos) ─────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# ── Backblaze B2 (stockage vidéos) ───────────────────────────
# CORRECTION : Champs B2 manquants dans l'original (B2_KEY_ID, B2_APP_KEY, etc.)
B2_KEY_ID=0031b74f6b8a6180000000001
B2_APP_KEY=votre_application_key
B2_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
B2_BUCKET_NAME=burkinavista-videos
B2_PUBLIC_URL=https://burkinavistabf.poodasamuel.com

# ── Gemini API (IA SEO — gratuit) ────────────────────────────
GEMINI_API_KEY=votre_gemini_api_key

# ── Resend (envoi emails) ─────────────────────────────────────
RESEND_API_KEY=votre_resend_api_key
RESEND_FROM_EMAIL=noreply@burkinavista.poodasamuel.com
# Email de réception des messages de contact et notifications admin
CONTACT_EMAIL=BurkinaVista@gmail.com

# ── Auth admin (JWT) ─────────────────────────────────────────
# CORRECTION : ADMIN_EMAIL et ADMIN_PASSWORD doivent être définis
ADMIN_PASSWORD=votre_mot_de_passe_admin_fort
ADMIN_EMAIL=votre@email-admin.com
# JWT_SECRET : générer avec : openssl rand -base64 32
JWT_SECRET=votre_jwt_secret_aleatoire_minimum_32_chars

# ── URL publique de l'application ────────────────────────────
NEXT_PUBLIC_APP_URL=https://burkina-vista.vercel.app

# ── Vercel Cron (sécurité endpoint GET /api/cron/newsletter) ─
# Générer avec : openssl rand -hex 32
CRON_SECRET=votre_cron_secret_aleatoire

# ── Variables supprimées (non utilisées dans le code actuel) ─
# Les variables suivantes étaient dans l'exemple original mais non utilisées :
# CLOUDFLARE_ACCOUNT_ID — non utilisé (Cloudinary est utilisé à la place)
# CLOUDFLARE_STREAM_API_TOKEN — non utilisé (B2 est utilisé à la place)