# ============================
# BurkinaVista — Variables d'environnement
# ============================

# Neon PostgreSQL
DATABASE_URL=

# Cloudinary (stockage photos)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Cloudflare Stream (stockage vidéos)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=

# Gemini API (IA SEO — gratuit)
GEMINI_API_KEY=

# Resend (envoi emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@burkinavista.com

# Auth admin (cookie JWT — pas d'OAuth, pas de Supabase)
ADMIN_PASSWORD=
ADMIN_EMAIL=
JWT_SECRET=

# URL publique de l'application
NEXT_PUBLIC_APP_URL=https://burkina-vista.vercel.app

# Vercel Cron — sécurité du endpoint GET /api/cron/newsletter
CRON_SECRET=burkinavista_cron_2025_secret_long

