# ============================
# BurkinaVista — Variables d'environnement
# ============================
# IMPORTANT : Ne jamais commiter ce fichier avec de vraies valeurs !
# Copier vers .env.local et remplir les valeurs

# ── Neon PostgreSQL ──────────────────────────────────────────
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ── Cloudinary (stockage photos) ─────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# ── Backblaze B2 (stockage vidéos) ───────────────────────────
B2_KEY_ID=0031b74f6b8a6180000000001
B2_APP_KEY=votre_application_key
B2_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
B2_BUCKET_NAME=burkinavista-videos

# ╔══════════════════════════════════════════════════════════════════╗
# ║  CORRECTION CRITIQUE — ROOT CAUSE DES 404 VIDÉO               ║
# ║                                                                  ║
# ║  ANCIENNE VALEUR (ERRONÉE) :                                     ║
# ║    B2_PUBLIC_URL=https://burkinavistabf.poodasamuel.com          ║
# ║                                                                  ║
# ║  Avec cette valeur le code générait :                            ║
# ║    https://burkinavistabf.poodasamuel.com/videos/xxx.mp4         ║
# ║  → 404 car Cloudflare ne route PAS ce chemin vers B2             ║
# ║                                                                  ║
# ║  NOUVELLE VALEUR CORRECTE :                                      ║
# ║    B2_PUBLIC_URL=https://burkinavistabf.poodasamuel.com/file/burkinavista-videos ║
# ║                                                                  ║
# ║  Avec cette valeur le code génère :                              ║
# ║    https://burkinavistabf.poodasamuel.com/file/burkinavista-videos/videos/xxx.mp4 ║
# ║  → 200 ✅ car c'est le chemin natif B2 que Cloudflare proxifie  ║
# ║                                                                  ║
# ║  POURQUOI : Le CNAME pointe vers l'endpoint S3 de B2             ║
# ║  (burkinavista-videos.s3.eu-central-003.backblazeb2.com).        ║
# ║  Cloudflare route /file/{bucket}/{key} vers B2 nativement.       ║
# ║  Les chemins /videos/xxx.mp4 ne sont pas routés → 404.           ║
# ╚══════════════════════════════════════════════════════════════════╝
B2_PUBLIC_URL=https://burkinavistabf.poodasamuel.com/file/burkinavista-videos

# ── Gemini API (IA SEO — gratuit) ────────────────────────────
GEMINI_API_KEY=votre_gemini_api_key

# ── Resend (envoi emails) ─────────────────────────────────────
RESEND_API_KEY=votre_resend_api_key
RESEND_FROM_EMAIL=noreply@burkinavista.poodasamuel.com
# Email de réception des messages de contact et notifications admin
CONTACT_EMAIL=BurkinaVista@gmail.com

# ── Auth admin (JWT) ─────────────────────────────────────────
# [LOGIN-01] ADMIN_PASSWORD est désormais déprécié (mais conservé en fallback).
# UTILISER ADMIN_PASSWORD_HASH généré par le script :
#   node scripts/generate-admin-hash.mjs "MotDePasseFort"
# Format : scrypt$N$r$p$<salt>$<hash>
ADMIN_PASSWORD_HASH=scrypt$16384$8$1$<saltBase64>$<hashBase64>
# Fallback legacy (si ADMIN_PASSWORD_HASH absent) — à retirer dès que possible
ADMIN_PASSWORD=votre_mot_de_passe_admin_fort
ADMIN_EMAIL=votre@email-admin.com
# [JWT-01] JWT_SECRET OBLIGATOIRE en production (plus de fallback hardcodé)
# Générer avec : openssl rand -base64 32
JWT_SECRET=votre_jwt_secret_aleatoire_minimum_32_chars

# ── URL publique de l'application ────────────────────────────
NEXT_PUBLIC_APP_URL=https://burkina-vista.vercel.app

# ── Vercel Cron (sécurité endpoint GET /api/cron/newsletter) ─
# Générer avec : openssl rand -hex 32
CRON_SECRET=votre_cron_secret_aleatoire

# ============================
# AJOUTS AUDIT 2026-05-01 — Sécurité & anti-abus
# ============================

# ── [RATE-LIMIT-01] Upstash Redis — Rate-limiting IP (free tier 10k cmd/jour) ──
# Créer une base sur https://upstash.com/ → REST API
# Si non configuré : le rate-limiting est silencieusement désactivé (failsafe)
UPSTASH_REDIS_REST_URL=https://votre-region-12345.upstash.io
UPSTASH_REDIS_REST_TOKEN=votre_token_upstash_redis

# ── [TURNSTILE-01] Cloudflare Turnstile (Captcha — alternative gratuite à reCAPTCHA) ──
# Créer un site sur https://dash.cloudflare.com/?to=/:account/turnstile
# Si non configuré : la vérification captcha est silencieusement désactivée (failsafe)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA_votre_site_key_publique
TURNSTILE_SECRET_KEY=0x4AAAAAAA_votre_secret_key_serveur

# ── [VIRUSTOTAL-01] VirusTotal (scan de fichiers uploadés — optionnel) ──
# Free tier : 4 requêtes/min, 500/jour. https://www.virustotal.com/
# Si non configuré : le scan est silencieusement désactivé (les uploads passent)
VIRUSTOTAL_API_KEY=votre_clef_api_virustotal